				"source": [
					"%%pyspark\r\n",
					"df1 = spark.read.load('abfss://landing@storeadlsaccount.dfs.core.windows.net/Project/silverlayer/CustomerAddress/', format='parquet')\r\n",
					"df1=df1.withColumnRenamed(\"modifieddate\", \"modifieddate_address\")\r\n",
					"df1=df1.withColumnRenamed(\"rowguid\", \"rowguid_address\")\r\n",
					"df2=spark.read.load('abfss://landing@storeadlsaccount.dfs.core.windows.net/Project/silverlayer/Customer/', format='parquet')\r\n",
					"df3=df1.join(df2, on='CustomerID')\r\n",
					"df3.write.mode('overwrite').save(path='abfss://landing@storeadlsaccount.dfs.core.windows.net/Project/goldlayer/UseCase/')"
				]
